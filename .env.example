# Environment variables for the damage claim verification pipeline
# Copy this file to .env and fill in your values.
# .env is gitignored -- NEVER commit the real .env file.

# Required: your Gemini API key from https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override model (default: gemini-2.5-flash)
# Use gemini-2.0-flash for paid accounts with higher quota
# GEMINI_MODEL=gemini-2.5-flash

# Optional: seconds between API calls (default: 7)
# GEMINI_DELAY=7
